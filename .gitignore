# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Data ---
# Ignore everything in data/ by default (raw/large STIX downloads),
# but keep processed CSV catalogs tracked, wherever they live inside data/.
data/*
!data/**/
!data/**/*.csv
!data/*.csv

# --- Reference papers (copyrighted PDFs) ---
papers/

# --- Figures (usually regenerable from notebooks; uncomment to ignore) ---
# figures/

# --- OS / editor junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Environment / secrets ---
.env
*.env

# --- Logs ---
*.log
